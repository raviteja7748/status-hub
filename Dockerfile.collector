FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/status-collector ./cmd/collector

FROM gcr.io/distroless/base-debian12
WORKDIR /app
COPY --from=build /out/status-collector /app/status-collector
ENTRYPOINT ["/app/status-collector"]

